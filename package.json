{
  "name": "selickiy-space",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start -H 127.0.0.1 -p 3000",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prisma:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "seed": "tsx prisma/seed.ts",
    "verify": "npm run prisma:generate && npm run lint && npm run typecheck && npm run test && npm run build",
    "verify:deployment": "tsx scripts/verify-deployment.ts"
  },
  "engines": {
    "node": "22.x",
    "npm": ">=10 <12"
  },
  "dependencies": {
    "@phosphor-icons/react": "2.1.10",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "@tiptap/extension-link": "3.27.3",
    "@tiptap/pm": "3.27.3",
    "@tiptap/react": "3.27.3",
    "@tiptap/starter-kit": "3.27.3",
    "file-type": "22.0.1",
    "next": "16.2.10",
    "next-auth": "4.24.14",
    "next-themes": "0.4.6",
    "pg": "8.22.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "sanitize-html": "2.17.5",
    "slugify": "1.6.9",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.3.2",
    "@types/node": "22.20.1",
    "@types/pg": "8.20.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/sanitize-html": "2.16.1",
    "eslint": "9.39.3",
    "eslint-config-next": "16.2.10",
    "prisma": "7.8.0",
    "tailwindcss": "4.3.2",
    "tsx": "4.23.0",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  },
  "overrides": {
    "@hono/node-server": "1.19.13",
    "fast-uri": "3.1.2",
    "hono": "4.12.25",
    "postcss": "8.5.16",
    "uuid": "11.1.1"
  }
